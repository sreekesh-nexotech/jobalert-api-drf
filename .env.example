# Copy to .env and fill in real values
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave blank for local SQLite default
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# JWT
JWT_SIGNING_KEY=
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# Email (OTP delivery)
# Dev default = console backend (prints emails to stdout). For Google Workspace:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=noreply@your-domain.com
#   EMAIL_HOST_PASSWORD=xxxxxxxxxxxxxxxx     # 16-char Google App Password
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Job Alert <noreply@jobalert.local>

# Default administrator account
# A data migration auto-creates / promotes this user with full write access.
# Set DEFAULT_ADMIN_SKIP_BOOTSTRAP=True to skip provisioning (e.g. CI).
DEFAULT_ADMIN_EMAIL=admin@jobalert.local
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_SKIP_BOOTSTRAP=False
